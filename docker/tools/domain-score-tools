#!/usr/bin/env bash
set -u

COMMAND="${1:-}"
shift || true

DOMAIN=""
URL=""
TOOLS=""
OUT="/work"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --domain)
      DOMAIN="${2:-}"
      shift 2
      ;;
    --url)
      URL="${2:-}"
      shift 2
      ;;
    --tools)
      TOOLS="${2:-}"
      shift 2
      ;;
    --out)
      OUT="${2:-}"
      shift 2
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

if [[ "$COMMAND" != "scan" ]]; then
  echo "usage: domain-score-tools scan --domain example.com --url https://example.com --tools subfinder,httpx --out /work" >&2
  exit 2
fi

if [[ -z "$DOMAIN" ]]; then
  echo "--domain is required" >&2
  exit 2
fi

if [[ -z "$URL" ]]; then
  URL="https://${DOMAIN}"
fi

RAW="${OUT}/raw"
mkdir -p "$RAW"

log() {
  printf 'domain-score tools container: %s\n' "$*" >&2
}

run_step() {
  local name="$1"
  local stdout_file="$2"
  local stderr_file="$3"
  shift 3
  local started="$SECONDS"
  log "start ${name}"
  while true; do
    sleep 30
    log "still running ${name} ($((SECONDS - started))s)"
  done &
  local heartbeat_pid=$!
  "$@" > >(tee "$stdout_file") 2> >(tee "$stderr_file" >&2)
  local rc=$?
  kill "$heartbeat_pid" 2>/dev/null || true
  wait "$heartbeat_pid" 2>/dev/null || true
  local elapsed=$((SECONDS - started))
  if [[ "$rc" -eq 0 ]]; then
    log "done ${name} (${elapsed}s)"
  else
    log "done ${name} with exit ${rc} (${elapsed}s; continuing, see raw/${name}.stderr)"
  fi
  return 0
}

has_tool() {
  local needle="$1"
  [[ ",${TOOLS}," == *",${needle},"* ]]
}

write_tool_finding() {
  local file="$1"
  local tool="$2"
  local severity="$3"
  local title="$4"
  local recommendation="$5"
  jq -n \
    --arg source "external_tool" \
    --arg tool "$tool" \
    --arg asset "$DOMAIN" \
    --arg type "tool_status" \
    --arg severity "$severity" \
    --arg title "$title" \
    --arg recommendation "$recommendation" \
    '[{source:$source, tool:$tool, asset:$asset, type:$type, severity:$severity, title:$title, recommendation:$recommendation}]' \
    > "$file"
}

build_targets() {
  local targets="${OUT}/targets.txt"
  : > "$targets"
  if [[ -s "${RAW}/subfinder.jsonl" ]]; then
    jq -r '.host? // empty' "${RAW}/subfinder.jsonl" >> "$targets" 2>/dev/null || true
  fi
  if [[ -s "${RAW}/amass.jsonl" ]]; then
    jq -r '.name? // empty' "${RAW}/amass.jsonl" >> "$targets" 2>/dev/null || true
  fi
  if [[ -s "${RAW}/amass.txt" ]]; then
    sed '/^[[:space:]]*$/d' "${RAW}/amass.txt" >> "$targets" 2>/dev/null || true
  fi
  echo "$DOMAIN" >> "$targets"
  sort -u "$targets" -o "$targets"
  log "targets prepared: $(wc -l < "$targets" | tr -d ' ')"
  echo "$targets"
}

build_urls() {
  local urls="${OUT}/urls.txt"
  : > "$urls"
  if [[ -s "${RAW}/httpx.jsonl" ]]; then
    jq -r '.url? // .input? // empty' "${RAW}/httpx.jsonl" >> "$urls" 2>/dev/null || true
  fi
  if [[ ! -s "$urls" ]]; then
    echo "$URL" >> "$urls"
  fi
  sort -u "$urls" -o "$urls"
  log "urls prepared: $(wc -l < "$urls" | tr -d ' ')"
  echo "$urls"
}

log "scan started for ${DOMAIN}; tools=${TOOLS}; raw=${RAW}"

if has_tool "subfinder"; then
  run_step "subfinder" "${RAW}/subfinder.stdout" "${RAW}/subfinder.stderr" \
    subfinder -d "$DOMAIN" -json -silent -o "${RAW}/subfinder.jsonl"
fi

if has_tool "amass"; then
  run_step "amass" "${RAW}/amass.txt" "${RAW}/amass.stderr" \
    amass enum -passive -d "$DOMAIN" -silent
  pkill -f "/usr/local/bin/amass engine" 2>/dev/null || true
fi

TARGETS="$(build_targets)"

if has_tool "httpx"; then
  run_step "httpx" "${RAW}/httpx.stdout" "${RAW}/httpx.stderr" \
    httpx -l "$TARGETS" -json -silent -status-code -title -tech-detect -location -tls-probe -follow-redirects -o "${RAW}/httpx.jsonl"
fi

URLS="$(build_urls)"

if has_tool "naabu"; then
  run_step "naabu" "${RAW}/naabu.stdout" "${RAW}/naabu.stderr" \
    naabu -list "$TARGETS" -json -silent -top-ports 100 -o "${RAW}/naabu.jsonl"
fi

if has_tool "nuclei"; then
  run_step "nuclei" "${RAW}/nuclei.stdout" "${RAW}/nuclei.stderr" \
    nuclei -l "$URLS" -jsonl -templates /opt/nuclei-templates -severity low,medium,high,critical -rate-limit 5 -stats -stats-interval 30 -o "${RAW}/nuclei.jsonl"
fi

if has_tool "testssl"; then
  run_step "testssl" "${RAW}/testssl.stdout" "${RAW}/testssl.stderr" \
    testssl.sh --fast --warnings off --jsonfile "${RAW}/testssl.json" "$DOMAIN"
fi

if has_tool "zap"; then
  run_step "zap" "${RAW}/zap.stdout" "${RAW}/zap.stderr" \
    zap-baseline.py -t "$URL" -J "${RAW}/zap.json" -I -m 1
fi

if has_tool "internetnl"; then
  log "start internetnl"
  write_tool_finding \
    "${RAW}/internetnl.json" \
    "internetnl" \
    "info" \
    "Internet.nl local source is present in the tools image" \
    "Internet.nl is a multi-service compliance stack. The image includes the source tree for local operation; use the normalized domain-score checks and future service mode for full Internet.nl parity."
  log "done internetnl"
fi

if has_tool "greenbone"; then
  log "start greenbone"
  write_tool_finding \
    "${RAW}/greenbone.json" \
    "greenbone" \
    "info" \
    "Greenbone client components are present in the tools image" \
    "Greenbone Community Edition is a multi-service vulnerability management stack with feeds and database initialization. Use this image as the controlled runtime base; future releases can persist and initialize the full service state."
  log "done greenbone"
fi

log "scan finished"
exit 0
