#!/usr/bin/env bash
set -u

COMMAND="${1:-}"
shift || true

DOMAIN=""
URL=""
TOOLS=""
OUT="/work"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --domain)
      DOMAIN="${2:-}"
      shift 2
      ;;
    --url)
      URL="${2:-}"
      shift 2
      ;;
    --tools)
      TOOLS="${2:-}"
      shift 2
      ;;
    --out)
      OUT="${2:-}"
      shift 2
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

if [[ "$COMMAND" != "scan" ]]; then
  echo "usage: domain-score-tools scan --domain example.com --url https://example.com --tools subfinder,httpx --out /work" >&2
  exit 2
fi

if [[ -z "$DOMAIN" ]]; then
  echo "--domain is required" >&2
  exit 2
fi

if [[ -z "$URL" ]]; then
  URL="https://${DOMAIN}"
fi

RAW="${OUT}/raw"
mkdir -p "$RAW"

log() {
  printf 'domain-score tools container: %s\n' "$*" >&2
}

run_step() {
  local name="$1"
  local stdout_file="$2"
  local stderr_file="$3"
  shift 3
  local started="$SECONDS"
  printf '{"tool":"%s","status":"started"}\n' "$name" > "${RAW}/${name}.started"
  log "start ${name}"
  while true; do
    sleep 30
    log "still running ${name} ($((SECONDS - started))s)"
  done &
  local heartbeat_pid=$!
  "$@" > >(tee "$stdout_file") 2> >(tee "$stderr_file" >&2)
  local rc=$?
  kill "$heartbeat_pid" 2>/dev/null || true
  wait "$heartbeat_pid" 2>/dev/null || true
  local elapsed=$((SECONDS - started))
  if [[ "$rc" -eq 0 ]]; then
    log "done ${name} (${elapsed}s)"
  else
    log "done ${name} with exit ${rc} (${elapsed}s; continuing, see raw/${name}.stderr)"
  fi
  jq -n \
    --arg tool "$name" \
    --arg status "done" \
    --argjson exit_code "$rc" \
    --argjson elapsed_seconds "$elapsed" \
    '{tool:$tool,status:$status,exit_code:$exit_code,elapsed_seconds:$elapsed_seconds}' \
    > "${RAW}/${name}.status" 2>/dev/null || true
  return 0
}

has_tool() {
  local needle="$1"
  [[ ",${TOOLS}," == *",${needle},"* ]]
}

write_tool_finding() {
  local file="$1"
  local tool="$2"
  local severity="$3"
  local title="$4"
  local recommendation="$5"
  jq -n \
    --arg source "external_tool" \
    --arg tool "$tool" \
    --arg asset "$DOMAIN" \
    --arg type "tool_status" \
    --arg severity "$severity" \
    --arg title "$title" \
    --arg recommendation "$recommendation" \
    '[{source:$source, tool:$tool, asset:$asset, type:$type, severity:$severity, title:$title, recommendation:$recommendation}]' \
    > "$file"
}

run_internetnl_public_site() {
  local headers="${RAW}/internetnl.headers"
  local initial="${RAW}/internetnl.initial.html"
  local probes="${RAW}/internetnl.probes.jsonl"
  local result="${RAW}/internetnl.result.html"
  local meta="${RAW}/internetnl.meta.json"
  local findings="${RAW}/internetnl.json"
  local base="https://internet.nl"
  local probe_url="${base}/site/probes/${DOMAIN}/"
  local result_url="${base}/site/${DOMAIN}/results"

  : > "$probes"
  curl -fsSL -D "$headers" -o "$initial" -X POST --data-urlencode "url=${DOMAIN}" "${base}/site/"

  local done_state="false"
  for _ in $(seq 1 70); do
    local probe_body
    probe_body="$(curl -fsSL "$probe_url")"
    printf '%s\n' "$probe_body" >> "$probes"
    done_state="$(printf '%s' "$probe_body" | jq -r 'all(.[]; .done == true)')"
    if [[ "$done_state" == "true" ]]; then
      break
    fi
    sleep 3
  done

  if [[ "$done_state" != "true" ]]; then
    echo "Internet.nl probes did not finish before timeout" >&2
    return 75
  fi

  local final_url
  final_url="$(curl -fsSL -w '%{url_effective}' -o "$result" "$result_url")"
  jq -n --arg domain "$DOMAIN" --arg probe_url "$probe_url" --arg result_url "$final_url" \
    '{domain:$domain, probe_url:$probe_url, result_url:$result_url}' > "$meta"

  python3 - "$DOMAIN" "$result" "$meta" "$findings" <<'PY'
import html
import json
import re
import sys

domain, result_path, meta_path, findings_path = sys.argv[1:5]
with open(result_path, "r", encoding="utf-8", errors="replace") as fh:
    doc = fh.read()
with open(meta_path, "r", encoding="utf-8") as fh:
    meta = json.load(fh)

def clean(value):
    value = re.sub(r"<[^>]+>", " ", value)
    return " ".join(html.unescape(value).split())

score = None
m = re.search(r'data-resultscore="([0-9]+)"', doc)
if m:
    score = int(m.group(1))

findings = []
if score is not None and score < 100:
    findings.append({
        "source": "external_tool",
        "tool": "internetnl",
        "asset": domain,
        "type": "internetnl_score",
        "severity": "low" if score >= 80 else "medium",
        "title": f"Internet.nl website score is {score}%",
        "evidence": {"score": score, "result_url": meta.get("result_url")},
        "recommendation": "Review failed and warning Internet.nl categories and align the domain with modern internet standards."
    })

for match in re.finditer(r'<li class="main-item ([^"]+)" id="([^"]+)".*?<a href="[^"]*">(.*?)</a>', doc, re.S):
    status, item_id, body = match.groups()
    status = status.strip()
    if status == "passed":
        continue
    title = clean(body)
    severity = {
        "failed": "medium",
        "warning": "low",
        "error": "medium",
    }.get(status, "info")
    findings.append({
        "source": "external_tool",
        "tool": "internetnl",
        "asset": domain,
        "type": "internetnl_category",
        "severity": severity,
        "title": title,
        "evidence": {"status": status, "category": item_id, "result_url": meta.get("result_url")},
        "recommendation": "Open the Internet.nl result URL and fix the failing or recommended standards category."
    })

with open(findings_path, "w", encoding="utf-8") as fh:
    json.dump(findings, fh, ensure_ascii=False, indent=2)
    fh.write("\n")
PY
}

run_greenbone_service_notice() {
  write_tool_finding \
    "${RAW}/greenbone.json" \
    "greenbone" \
    "info" \
    "Greenbone Community Edition service stack is not running" \
    "Greenbone CE is a multi-container service with feeds, Redis, PostgreSQL, gvmd and OpenVAS. Start a persistent Greenbone service runtime and connect domain-score to it; the one-shot tools image will not pretend this completed."
  echo "Greenbone CE requires a running persistent service stack; one-shot docker run cannot perform a real Greenbone scan without gvmd/OpenVAS/feed state." >&2
  return 78
}

build_targets() {
  local targets="${OUT}/targets.txt"
  : > "$targets"
  if [[ -s "${RAW}/subfinder.jsonl" ]]; then
    jq -r '.host? // empty' "${RAW}/subfinder.jsonl" >> "$targets" 2>/dev/null || true
  fi
  if [[ -s "${RAW}/amass.jsonl" ]]; then
    jq -r '.name? // empty' "${RAW}/amass.jsonl" >> "$targets" 2>/dev/null || true
  fi
  if [[ -s "${RAW}/amass.txt" ]]; then
    sed '/^[[:space:]]*$/d' "${RAW}/amass.txt" >> "$targets" 2>/dev/null || true
  fi
  echo "$DOMAIN" >> "$targets"
  sort -u "$targets" -o "$targets"
  log "targets prepared: $(wc -l < "$targets" | tr -d ' ')"
  echo "$targets"
}

build_urls() {
  local urls="${OUT}/urls.txt"
  : > "$urls"
  if [[ -s "${RAW}/httpx.jsonl" ]]; then
    jq -r '.url? // .input? // empty' "${RAW}/httpx.jsonl" >> "$urls" 2>/dev/null || true
  fi
  if [[ ! -s "$urls" ]]; then
    echo "$URL" >> "$urls"
  fi
  sort -u "$urls" -o "$urls"
  log "urls prepared: $(wc -l < "$urls" | tr -d ' ')"
  echo "$urls"
}

log "scan started for ${DOMAIN}; tools=${TOOLS}; raw=${RAW}"

if has_tool "subfinder"; then
  run_step "subfinder" "${RAW}/subfinder.stdout" "${RAW}/subfinder.stderr" \
    subfinder -d "$DOMAIN" -json -silent -o "${RAW}/subfinder.jsonl"
fi

if has_tool "amass"; then
  run_step "amass" "${RAW}/amass.txt" "${RAW}/amass.stderr" \
    amass enum -passive -d "$DOMAIN" -silent
  pkill -f "/usr/local/bin/amass engine" 2>/dev/null || true
fi

TARGETS="$(build_targets)"

if has_tool "httpx"; then
  run_step "httpx" "${RAW}/httpx.stdout" "${RAW}/httpx.stderr" \
    httpx -l "$TARGETS" -json -silent -status-code -title -tech-detect -location -tls-probe -follow-redirects -o "${RAW}/httpx.jsonl"
fi

URLS="$(build_urls)"

if has_tool "naabu"; then
  run_step "naabu" "${RAW}/naabu.stdout" "${RAW}/naabu.stderr" \
    naabu -list "$TARGETS" -json -silent -top-ports 100 -o "${RAW}/naabu.jsonl"
fi

if has_tool "nuclei"; then
  run_step "nuclei" "${RAW}/nuclei.stdout" "${RAW}/nuclei.stderr" \
    nuclei -l "$URLS" -jsonl -templates /opt/nuclei-templates -severity low,medium,high,critical -rate-limit 5 -stats -stats-interval 30 -o "${RAW}/nuclei.jsonl"
fi

if has_tool "testssl"; then
  run_step "testssl" "${RAW}/testssl.stdout" "${RAW}/testssl.stderr" \
    testssl.sh --fast --warnings off --jsonfile "${RAW}/testssl.json" "$DOMAIN"
fi

if has_tool "zap"; then
  mkdir -p /tmp/zap-home
  run_step "zap" "${RAW}/zap.stdout" "${RAW}/zap.stderr" \
    bash -lc 'cd /zap/wrk && /zap/zap-baseline.py -t "$1" -J raw/zap.json -I -m 1 -z "-dir /tmp/zap-home"' _ "$URL"
fi

if has_tool "internetnl"; then
  run_step "internetnl" "${RAW}/internetnl.stdout" "${RAW}/internetnl.stderr" \
    run_internetnl_public_site
fi

if has_tool "greenbone"; then
  run_step "greenbone" "${RAW}/greenbone.stdout" "${RAW}/greenbone.stderr" \
    run_greenbone_service_notice
fi

log "scan finished"
exit 0
